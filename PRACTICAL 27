import java.io.*;

public class StudentFileDemo {
    public static void main(String[] args) {

        FileWriter fw = null;
        BufferedWriter bw = null;
        BufferedReader br = null;

        try {
            fw = new FileWriter("students.txt");
            bw = new BufferedWriter(fw);

            bw.write("101 John 85");
            bw.newLine();
            bw.write("102 Alice 90");
            bw.newLine();
            bw.write("103 Bob 78");
            bw.newLine();

            bw.flush();

            System.out.println("Student records written successfully.\n");
            br = new BufferedReader(new FileReader("students.txt"));

            String line;
            System.out.println("Reading student records:\n");

            while ((line = br.readLine()) != null) {
                System.out.println(line);
            }

        } catch (IOException e) {
            System.out.println("File error: " + e.getMessage());

        } finally {
            try {
                if (bw != null) bw.close();
                if (fw != null) fw.close();
                if (br != null) br.close();
            } catch (IOException e) {
                System.out.println("Error closing file: " + e.getMessage());
            }

            System.out.println("\nProgram execution completed.");
        }
    }
}
