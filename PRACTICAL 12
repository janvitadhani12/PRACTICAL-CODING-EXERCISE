class VolumeCalculator {
    public double calculateVolume(double side) {
        return side * side * side;
    }
    public double calculateVolume(double length, double width, double height) {
        return length * width * height;
    }
    public double calculateVolume(double radius, boolean isSphere) {
        // Using boolean just to differentiate method signature
        if (isSphere) {
            return (4.0 / 3.0) * Math.PI * radius * radius * radius;
        }
        return 0;
    }
}
public class VolumeTest {
    public static void main(String[] args) {
        VolumeCalculator vc = new VolumeCalculator();
        double cubeVolume = vc.calculateVolume(3);
        System.out.println("Cube Volume: " + cubeVolume);
        double cuboidVolume = vc.calculateVolume(4, 5, 6);
        System.out.println("Cuboid Volume: " + cuboidVolume);
        double sphereVolume = vc.calculateVolume(3, true);
        System.out.println("Sphere Volume: " + sphereVolume);
    }
}
